{
  "manifest_version": 3,
  "name": "Timestamp Converter",
  "version": "2.0",
  "description": "Highlight any timestamp, right-click, and convert it to your chosen timezone.",
  "permissions": ["contextMenus", "activeTab", "scripting", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Timestamp Converter Settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
